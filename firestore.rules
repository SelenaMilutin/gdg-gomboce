rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: profiles
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - role: string (required, 'senior' | 'caregiver')
    //   - age: number (optional)
    //   - primaryCaregiver: string (optional)
    //   - emergencyPhone: string (optional)
    //   - medications: string (optional)
    //   - notes: string (optional)
    //   - linkedSeniorId: string (optional, for caregivers)
    //
    // Collection: reminders
    // Document ID: reminderId
    // Fields:
    //   - title: string (required)
    //   - icon: string (optional)
    //   - time: string (required)
    //   - repeat: string (optional)
    //   - agent: string (optional)
    //   - note: string (optional)
    //   - completed: bool (optional)
    //   - userId: string (required, immutable)
    //
    // Collection: activityLog
    // Document ID: logId
    // Fields:
    //   - timestamp: timestamp (required)
    //   - agent: string (required)
    //   - type: string (required)
    //   - outcome: string (required)
    //   - message: string (optional)
    //   - userId: string (required, immutable)
    //
    // Collection: locations
    // Document ID: userId
    // Fields:
    //   - latitude: number (required)
    //   - longitude: number (required)
    //   - lastUpdated: timestamp (required)
    //   - userId: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isSharedDemo(userId) {
      return userId == 'shared-demo-senior';
    }

    function isOwner(userId) {
      return isSharedDemo(userId) || (isAuthenticated() && request.auth.uid == userId);
    }

    function isLinkedCaregiver(seniorId) {
      return isSharedDemo(seniorId) || (isAuthenticated() && (
        exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.linkedSeniorId == seniorId)
      );
    }

    function isDocOwner() {
      return isSharedDemo(resource.data.userId) || (isAuthenticated() && request.auth.uid == resource.data.userId);
    }

    function isDocLinkedCaregiver() {
      return isSharedDemo(resource.data.userId) || (isAuthenticated() && (
        exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.linkedSeniorId == resource.data.userId)
      );
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "stojkoovs@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProfile(data) {
      return hasRequiredFields(['name', 'uid', 'role']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.uid is string &&
             data.role in ['senior', 'caregiver'];
    }

    function isValidReminder(data) {
      return hasRequiredFields(['title', 'time', 'userId']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.time is string &&
             data.userId is string;
    }

    function isValidActivityLog(data) {
      return hasRequiredFields(['timestamp', 'agent', 'type', 'outcome', 'userId']) &&
             data.timestamp is timestamp &&
             data.agent is string &&
             data.type is string &&
             data.outcome is string &&
             data.userId is string;
    }

    function isValidLocation(data) {
      return hasRequiredFields(['latitude', 'longitude', 'lastUpdated', 'userId']) &&
             data.latitude is number &&
             data.longitude is number &&
             data.lastUpdated is timestamp &&
             data.userId is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /profiles/{userId} {
      allow read: if isAuthenticated() || isSharedDemo(userId);
      allow create: if (isAuthenticated() || isSharedDemo(userId)) && isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidProfile(request.resource.data);
    }

    match /reminders/{reminderId} {
      allow read: if isDocOwner() || isDocLinkedCaregiver() || isAdmin();
      allow create: if (isAuthenticated() || isSharedDemo(request.resource.data.userId)) && isValidReminder(request.resource.data) && (isOwner(request.resource.data.userId) || isLinkedCaregiver(request.resource.data.userId));
      allow update: if (isDocOwner() || isDocLinkedCaregiver() || isAdmin()) && isValidReminder(request.resource.data);
      allow delete: if isDocOwner() || isDocLinkedCaregiver() || isAdmin();
    }

    match /activityLog/{logId} {
      allow read: if isDocOwner() || isDocLinkedCaregiver() || isAdmin();
      allow create: if (isAuthenticated() || isSharedDemo(request.resource.data.userId)) && isValidActivityLog(request.resource.data) && (isOwner(request.resource.data.userId) || isLinkedCaregiver(request.resource.data.userId));
      allow update: if (isDocOwner() || isDocLinkedCaregiver() || isAdmin()) && isValidActivityLog(request.resource.data);
      allow delete: if isAdmin();
    }

    match /locations/{userId} {
      allow read: if isOwner(userId) || isLinkedCaregiver(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidLocation(request.resource.data);
      allow update: if isOwner(userId) && isValidLocation(request.resource.data);
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
