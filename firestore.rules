rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: profiles
    // Document ID: userId
    // Fields:
    //   - name: string (required)
    //   - age: number (optional)
    //   - primaryCaregiver: string (optional)
    //   - emergencyPhone: string (optional)
    //   - medications: string (optional)
    //   - notes: string (optional)
    //   - userId: string (required, immutable)
    //
    // Collection: reminders
    // Document ID: reminderId
    // Fields:
    //   - title: string (required)
    //   - icon: string (optional)
    //   - time: string (required)
    //   - repeat: string (optional)
    //   - agent: string (optional)
    //   - note: string (optional)
    //   - completed: bool (optional)
    //   - userId: string (required, immutable)
    //
    // Collection: activityLog
    // Document ID: logId
    // Fields:
    //   - timestamp: timestamp (required)
    //   - agent: string (required)
    //   - type: string (required)
    //   - outcome: string (required)
    //   - message: string (optional)
    //   - userId: string (required, immutable)
    //
    // Collection: locations
    // Document ID: userId
    // Fields:
    //   - latitude: number (required)
    //   - longitude: number (required)
    //   - lastUpdated: timestamp (required)
    //   - userId: string (required, immutable)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function uidUnchanged() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == request.auth.uid;
    }

    function uidNotModified() {
      return !('userId' in request.resource.data) ||
        request.resource.data.userId == resource.data.userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function areImmutableFieldsUnchanged(fields) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(fields);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "stojkoovs@gmail.com" && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidProfile(data) {
      return hasRequiredFields(['name', 'userId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.userId is string;
    }

    function isValidReminder(data) {
      return hasRequiredFields(['title', 'time', 'userId']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.time is string &&
             data.userId is string;
    }

    function isValidActivityLog(data) {
      return hasRequiredFields(['timestamp', 'agent', 'type', 'outcome', 'userId']) &&
             data.timestamp is timestamp &&
             data.agent is string &&
             data.type is string &&
             data.outcome is string &&
             data.userId is string;
    }

    function isValidLocation(data) {
      return hasRequiredFields(['latitude', 'longitude', 'lastUpdated', 'userId']) &&
             data.latitude is number &&
             data.longitude is number &&
             data.lastUpdated is timestamp &&
             data.userId is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /profiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if (isOwner(userId) || isAdmin()) && isValidProfile(request.resource.data) && uidNotModified();
    }

    match /reminders/{reminderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidReminder(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && isValidReminder(request.resource.data) && uidNotModified();
      allow delete: if isDocOwner() || isAdmin();
    }

    match /activityLog/{logId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidActivityLog(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if (isDocOwner() || isAdmin()) && isValidActivityLog(request.resource.data) && uidNotModified();
      allow delete: if isAdmin();
    }

    match /locations/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidLocation(request.resource.data);
      allow update: if isOwner(userId) && isValidLocation(request.resource.data) && uidNotModified();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
