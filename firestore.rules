rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════
    // DATA MODEL
    // ═══════════════════════════════════════════════════════
    //
    // profiles/{userId}
    //   uid              : string   (required)
    //   name             : string   (required)
    //   role             : string   (required) 'senior' | 'caregiver'
    //   age              : number?
    //   primaryCaregiver : string?
    //   emergencyPhone   : string?
    //   medications      : string?
    //   notes            : string?
    //   linkedSeniorId   : string?  (caregivers only)
    //   createdAt        : timestamp
    //
    // reminders/{reminderId}
    //   title      : string    (required)
    //   time       : string    (required)
    //   userId     : string    (required, immutable) ← senior this belongs to
    //   createdBy  : string    (required, immutable) ← uid of creator
    //   icon       : string?
    //   repeat     : string?
    //   agent      : string?
    //   note       : string?
    //   completed  : bool?
    //   createdAt  : timestamp?
    //
    // activityLog/{logId}
    //   timestamp : timestamp  (required)
    //   agent     : string     (required)
    //   type      : string     (required)
    //   outcome   : string     (required)
    //   userId    : string     (required, immutable) ← senior this belongs to
    //   message   : string?
    //
    // locations/{seniorId}   ← document ID = senior's uid
    //   latitude    : number     (required)
    //   longitude   : number     (required)
    //   lastUpdated : timestamp  (required)
    //   userId      : string     (required)
    //
    // ═══════════════════════════════════════════════════════

    // ── Helpers ────────────────────────────────────────────

    function isAuthed() {
      return request.auth != null;
    }

    function isSharedDemo(uid) {
      return uid == 'shared-demo-senior';
    }

    function isSelf(uid) {
      return isAuthed() && request.auth.uid == uid;
    }

    // True if the caller is a caregiver linked to this seniorId
    function isLinkedCaregiverOf(seniorId) {
      return isSharedDemo(seniorId) || (
        isAuthed() &&
        exists(/databases/$(database)/documents/profiles/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', '') == 'caregiver' &&
        get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('linkedSeniorId', '') == seniorId
      );
    }

    // True if the caller may read/write data for this senior
    function canAccessSenior(seniorId) {
      return isSharedDemo(seniorId) || isSelf(seniorId) || isLinkedCaregiverOf(seniorId);
    }

    // Resource-level version of canAccessSenior
    function canAccessDoc() {
      return canAccessSenior(resource.data.userId);
    }

    function isAdmin() {
      return isAuthed() && (
        request.auth.token.get('email', '') == 'stojkoovs@gmail.com' &&
        request.auth.token.get('email_verified', false) == true
      );
    }

    // ── Validators ─────────────────────────────────────────

    function validProfile(d) {
      return d.keys().hasAll(['name', 'uid', 'role']) &&
             d.name is string && d.name.size() > 0 && d.name.size() < 100 &&
             d.uid  is string &&
             d.role in ['senior', 'caregiver'];
    }

    // Relaxed validator for senior profiles created by a caregiver —
    // name may be a placeholder if the caregiver left it blank.
    function validSeniorProfileByCaregiver(d) {
      return d.keys().hasAll(['name', 'uid', 'role', 'primaryCaregiver']) &&
             d.name             is string && d.name.size() > 0 && d.name.size() < 100 &&
             d.uid              is string &&
             d.role             == 'senior' &&
             d.primaryCaregiver is string && d.primaryCaregiver == request.auth.uid;
    }

    function validReminder(d) {
      return d.keys().hasAll(['title', 'time', 'userId', 'createdBy']) &&
             d.title     is string && d.title.size() > 0 && d.title.size() < 200 &&
             d.time      is string &&
             d.userId    is string &&
             d.createdBy is string;
    }

    function validActivityLog(d) {
      return d.keys().hasAll(['timestamp', 'agent', 'type', 'outcome', 'userId']) &&
             d.timestamp is timestamp &&
             d.agent     is string &&
             d.type      is string &&
             d.outcome   is string &&
             d.userId    is string;
    }

    function validLocation(d) {
      return d.keys().hasAll(['latitude', 'longitude', 'lastUpdated', 'userId']) &&
             d.latitude    is number &&
             d.longitude   is number &&
             d.lastUpdated is timestamp &&
             d.userId      is string;
    }

    // ── profiles ───────────────────────────────────────────

    match /profiles/{userId} {
      allow read: if isSelf(userId) ||
                     isLinkedCaregiverOf(userId) ||
                     isSharedDemo(userId) ||
                     isAdmin();

      // Caregivers need to read any senior profile to browse the list
      allow read: if isAuthed() &&
                     get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.get('role', '') == 'caregiver';

      // Normal self-registration (senior or caregiver creating their own profile)
      allow create: if (isSelf(userId) || isSharedDemo(userId)) &&
                       validProfile(request.resource.data);

      // ✅ FIX: Caregiver creating a "ghost" senior profile during registration.
      // The doc ID is auto-generated (not the caregiver's uid), so isSelf() fails.
      // We allow it if: caller is authed, the new doc is a senior, and
      // primaryCaregiver is set to the caller's own uid.
      allow create: if isAuthed() &&
                       validSeniorProfileByCaregiver(request.resource.data);

      allow update: if (isSelf(userId) || isAdmin()) &&
                       validProfile(request.resource.data);
    }

    // ── reminders ──────────────────────────────────────────

    match /reminders/{reminderId} {
      allow read: if canAccessDoc() || isAdmin();

      allow create: if isAuthed() &&
                       validReminder(request.resource.data) &&
                       canAccessSenior(request.resource.data.userId) &&
                       request.resource.data.createdBy == request.auth.uid;

      // userId and createdBy are immutable after creation
      allow update: if (canAccessDoc() || isAdmin()) &&
                       validReminder(request.resource.data) &&
                       request.resource.data.userId    == resource.data.userId &&
                       request.resource.data.createdBy == resource.data.createdBy;

      allow delete: if canAccessDoc() || isAdmin();
    }

    // ── activityLog ────────────────────────────────────────

    match /activityLog/{logId} {
      allow read: if canAccessDoc() || isAdmin();

      allow create: if isAuthed() &&
                       validActivityLog(request.resource.data) &&
                       canAccessSenior(request.resource.data.userId);

      // userId is immutable
      allow update: if (canAccessDoc() || isAdmin()) &&
                       validActivityLog(request.resource.data) &&
                       request.resource.data.userId == resource.data.userId;

      allow delete: if isAdmin();
    }

    // ── locations ──────────────────────────────────────────
    // Only the senior writes their own location; caregiver can read.

    match /locations/{userId} {
      allow read:   if isSelf(userId) || isLinkedCaregiverOf(userId) || isAdmin();
      allow create: if isSelf(userId) && validLocation(request.resource.data);
      allow update: if isSelf(userId) && validLocation(request.resource.data);
    }

    // Default deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
